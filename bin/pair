#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# pair - Claude Code × Codex ペアプロ自動化
# ============================================================
#
# 使い方:
#   pair "認証機能を実装して"
#   pair --mode review "リファクタリングして"
#   pair --mode ping-pong --rounds 5 "APIエンドポイントを追加"
#   pair --claude-first false "Codexに先に書かせたい"
#   pair --timeout 600 "重いタスク"

# --- デフォルト設定 ---
MODE="ping-pong"          # ping-pong | review | implement-review | parallel
ROUNDS=3                  # ラウンド数
CLAUDE_FIRST=true         # true: Claude先攻, false: Codex先攻
WORKDIR="$(pwd)"
LOG_DIR=".pair-logs"
HANDOFF=".pair-handoff.md" # ハンドオフメモ
CLAUDE_MODEL=""           # 空ならデフォルト
CODEX_MODEL=""            # 空ならデフォルト
TIMEOUT=900               # タイムアウト秒 (デフォルト15分)
VERBOSE=false             # 全出力を表示

# --- 色 ---
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# --- ヘルパー ---
log_claude()  { echo -e "${BLUE}${BOLD}[Claude]${NC} $*"; }
log_codex()   { echo -e "${GREEN}${BOLD}[Codex]${NC} $*"; }
log_info()    { echo -e "${CYAN}[Info]${NC} $*"; }
log_step()    { echo -e "\n${YELLOW}${BOLD}━━━ $* ━━━${NC}"; }
log_error()   { echo -e "${RED}[Error]${NC} $*" >&2; }
log_dim()     { echo -e "${DIM}  $*${NC}"; }

# 経過時間を見やすく
fmt_elapsed() {
  local sec="$1"
  if (( sec < 60 )); then
    echo "${sec}s"
  else
    echo "$((sec / 60))m$((sec % 60))s"
  fi
}

usage() {
  cat <<'USAGE'
Usage: pair [OPTIONS] "タスクの説明"

Options:
  --mode <mode>          動作モード (default: ping-pong)
                           ping-pong        : 交互に実装・改善
                           review           : 片方が実装、もう片方がレビュー
                           implement-review : Claude実装 → Codexレビュー → Claude修正
                           parallel         : 両方同時に実装 → マージ
  --rounds <n>           ラウンド数 (default: 3)
  --claude-first <bool>  Claude先攻 (default: true)
  --claude-model <model> Claude Code のモデル (例: opus, sonnet)
  --codex-model <model>  Codex のモデル (例: o3, o4-mini)
  --timeout <seconds>    各ターンのタイムアウト秒 (default: 900, 0=無制限)
  --verbose              全出力を表示
  --workdir <dir>        作業ディレクトリ (default: カレント)
  -h, --help             ヘルプ
USAGE
  exit 0
}

# --- 引数パース ---
TASK=""
while [[ $# -gt 0 ]]; do
  case $1 in
    --mode)          MODE="$2"; shift 2 ;;
    --rounds)        ROUNDS="$2"; shift 2 ;;
    --claude-first)  CLAUDE_FIRST="$2"; shift 2 ;;
    --claude-model)  CLAUDE_MODEL="$2"; shift 2 ;;
    --codex-model)   CODEX_MODEL="$2"; shift 2 ;;
    --timeout)       TIMEOUT="$2"; shift 2 ;;
    --verbose)       VERBOSE=true; shift ;;
    --workdir)       WORKDIR="$2"; shift 2 ;;
    -h|--help)       usage ;;
    -*)              log_error "Unknown option: $1"; usage ;;
    *)               TASK="$1"; shift ;;
  esac
done

if [[ -z "$TASK" ]]; then
  log_error "タスクを指定してください"
  usage
fi

# --- timeout 互換（macOS対応）---
# パイプ全体をタイムアウトさせるため、サブシェル + プロセスグループで管理
run_with_timeout() {
  local secs="$1"; shift
  if command -v timeout &>/dev/null; then
    timeout --signal=TERM "$secs" "$@"
  elif command -v gtimeout &>/dev/null; then
    gtimeout --signal=TERM "$secs" "$@"
  else
    "$@" &
    local pid=$!
    ( sleep "$secs" && kill "$pid" 2>/dev/null ) &
    local watcher=$!
    wait "$pid" 2>/dev/null
    local exit_code=$?
    kill "$watcher" 2>/dev/null
    wait "$watcher" 2>/dev/null
    return $exit_code
  fi
}

# パイプライン全体をタイムアウト付きで実行（サブシェルで囲む）
run_pipeline_with_timeout() {
  local secs="$1"; shift
  local script="$1"
  # サブシェルをバックグラウンドで実行し、プロセスグループごと管理
  bash -c "$script" &
  local pid=$!
  (
    sleep "$secs"
    # プロセスグループ全体を kill（パイプの子プロセスも含む）
    kill -- -"$pid" 2>/dev/null || kill "$pid" 2>/dev/null
  ) &
  local watcher=$!
  wait "$pid" 2>/dev/null
  local exit_code=$?
  kill "$watcher" 2>/dev/null
  wait "$watcher" 2>/dev/null
  return $exit_code
}

# --- 前提チェック ---
check_deps() {
  if ! command -v claude &>/dev/null; then
    log_error "claude CLI が見つかりません"
    exit 1
  fi
  if ! command -v npx &>/dev/null; then
    log_error "npx が見つかりません"
    exit 1
  fi
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    log_error "git リポジトリ内で実行してください"
    exit 1
  fi
}

# ============================================================
# Claude ストリーミング実行（リアルタイム進捗表示）
# ============================================================
run_claude() {
  local prompt="$1"
  local log_file="$2"
  local claude_args=(-p --output-format stream-json --verbose --permission-mode bypassPermissions)
  [[ -n "$CLAUDE_MODEL" ]] && claude_args+=(--model "$CLAUDE_MODEL")

  log_claude "開始..."

  # パイプライン全体をサブシェルで実行（タイムアウト対応）
  local start_ts
  start_ts=$(date +%s)

  (
    claude "${claude_args[@]}" "$prompt" 2>/dev/null \
      | tee "$log_file" \
      | while IFS= read -r line; do
          local msg_type
          msg_type=$(echo "$line" | sed -n 's/.*"type":"\([^"]*\)".*/\1/p')
          case "$msg_type" in
            assistant)
              if echo "$line" | grep -q '"type":"tool_use"'; then
                local tool_name
                tool_name=$(echo "$line" | sed -n 's/.*"name":"\([^"]*\)".*/\1/p' | head -1)
                if [[ -n "$tool_name" ]]; then
                  local elapsed=$(( $(date +%s) - start_ts ))
                  echo -e "  \033[2m[$(fmt_elapsed $elapsed)]\033[0m \033[0;34m▶\033[0m ${tool_name}"
                  local file_path
                  file_path=$(echo "$line" | sed -n 's/.*"file_path":"\([^"]*\)".*/\1/p' | head -1)
                  [[ -n "$file_path" ]] && echo -e "  \033[2m    → ${file_path##*/}\033[0m"
                  if [[ "$tool_name" == "Bash" ]]; then
                    local cmd
                    cmd=$(echo "$line" | sed -n 's/.*"command":"\([^"]*\)".*/\1/p' | head -1 | cut -c1-80)
                    [[ -n "$cmd" ]] && echo -e "  \033[2m    \$ ${cmd}\033[0m"
                  fi
                fi
              fi
              ;;
            result)
              local elapsed=$(( $(date +%s) - start_ts ))
              local cost turns
              cost=$(echo "$line" | sed -n 's/.*"total_cost_usd":\([0-9.]*\).*/\1/p')
              turns=$(echo "$line" | sed -n 's/.*"num_turns":\([0-9]*\).*/\1/p')
              echo -e "  \033[0;34m✓\033[0m 完了 $(fmt_elapsed $elapsed) | ${turns:-?}ターン | \$${cost:-?}"
              ;;
          esac
        done
  ) &
  local pipeline_pid=$!

  # タイムアウト監視（0 = 無制限）
  local watcher=""
  if (( TIMEOUT > 0 )); then
    (
      sleep "$TIMEOUT"
      kill -- -"$pipeline_pid" 2>/dev/null || kill "$pipeline_pid" 2>/dev/null
      echo -e "  \033[0;31m✗\033[0m タイムアウト (${TIMEOUT}s)"
    ) &
    watcher=$!
  fi

  wait "$pipeline_pid" 2>/dev/null
  local exit_code=$?
  [[ -n "$watcher" ]] && kill "$watcher" 2>/dev/null
  [[ -n "$watcher" ]] && wait "$watcher" 2>/dev/null
  return $exit_code
}

# ============================================================
# Codex ストリーミング実行（リトライ + フォールバック付き）
# ============================================================
_run_codex_once() {
  local prompt="$1"
  local log_file="$2"
  local use_json="$3"  # true/false
  local codex_args=(exec --full-auto)
  [[ "$use_json" == true ]] && codex_args+=(--json)
  [[ -n "$CODEX_MODEL" ]] && codex_args+=(-m "$CODEX_MODEL")

  local start_ts
  start_ts=$(date +%s)

  if [[ "$use_json" == true ]]; then
    # ストリーミング JSON モード（進捗表示あり）
    (
      npx @openai/codex "${codex_args[@]}" "$prompt" 2>/dev/null \
        | tee "$log_file" \
        | while IFS= read -r line; do
            local msg_type
            msg_type=$(echo "$line" | sed -n 's/.*"type":"\([^"]*\)".*/\1/p')
            case "$msg_type" in
              item.completed)
                local item_type
                item_type=$(echo "$line" | sed -n 's/.*"type":"\([^"]*\)".*"type":"\([^"]*\)".*/\2/p')
                local elapsed=$(( $(date +%s) - start_ts ))
                case "$item_type" in
                  tool_call|function_call)
                    local tool_name
                    tool_name=$(echo "$line" | sed -n 's/.*"name":"\([^"]*\)".*/\1/p' | head -1)
                    echo -e "  \033[2m[$(fmt_elapsed $elapsed)]\033[0m \033[0;32m▶\033[0m ${tool_name:-tool}"
                    ;;
                esac
                ;;
              turn.completed)
                local elapsed=$(( $(date +%s) - start_ts ))
                local in_tokens out_tokens
                in_tokens=$(echo "$line" | sed -n 's/.*"input_tokens":\([0-9]*\).*/\1/p')
                out_tokens=$(echo "$line" | sed -n 's/.*"output_tokens":\([0-9]*\).*/\1/p')
                echo -e "  \033[0;32m✓\033[0m ターン完了 $(fmt_elapsed $elapsed) | in:${in_tokens:-?} out:${out_tokens:-?}"
                ;;
              thread.completed|exec.completed)
                local elapsed=$(( $(date +%s) - start_ts ))
                echo -e "  \033[0;32m✓\033[0m 完了 $(fmt_elapsed $elapsed)"
                ;;
            esac
          done
    ) &
  else
    # プレーンテキストモード（フォールバック）
    (
      npx @openai/codex "${codex_args[@]}" "$prompt" 2>/dev/null \
        | tee "$log_file"
    ) &
  fi
  local pipeline_pid=$!

  # タイムアウト監視（0 = 無制限）
  local watcher=""
  if (( TIMEOUT > 0 )); then
    (
      sleep "$TIMEOUT"
      kill -- -"$pipeline_pid" 2>/dev/null || kill "$pipeline_pid" 2>/dev/null
      echo -e "  \033[0;31m✗\033[0m タイムアウト (${TIMEOUT}s)"
    ) &
    watcher=$!
  fi

  wait "$pipeline_pid" 2>/dev/null
  local exit_code=$?
  [[ -n "$watcher" ]] && kill "$watcher" 2>/dev/null
  [[ -n "$watcher" ]] && wait "$watcher" 2>/dev/null
  return $exit_code
}

run_codex() {
  local prompt="$1"
  local log_file="$2"
  local max_retries=2

  log_codex "開始..."

  local attempt
  for attempt in $(seq 1 $max_retries); do
    # 初回は --json 付き、リトライはなしで試す
    local use_json=true
    if (( attempt > 1 )); then
      use_json=false
      log_codex "リトライ ${attempt}/${max_retries}（--json なしフォールバック）..."
      sleep 2
    fi

    _run_codex_once "$prompt" "$log_file" "$use_json"
    local exit_code=$?

    # 成功 or タイムアウト → 終了
    if (( exit_code == 0 )); then
      return 0
    fi

    # segfault (139) / abort (134) / signal系 (128+) → リトライ
    if (( exit_code >= 128 && attempt < max_retries )); then
      log_error "Codex クラッシュ (exit ${exit_code})。リトライします..."
      : > "$log_file"  # ログクリア
      continue
    fi

    # その他のエラー → 終了
    log_error "Codex 失敗 (exit ${exit_code})"
    return $exit_code
  done

  return 1
}

# --- diff を取得（最大行数制限付き） ---
get_changes() {
  local diff status
  diff=$(git diff 2>/dev/null | head -200 || true)
  status=$(git status --short 2>/dev/null || true)
  if [[ -n "$diff" || -n "$status" ]]; then
    echo "### 現在の変更点"
    echo '```diff'
    echo "$diff"
    echo '```'
    echo "### ファイル状況"
    echo '```'
    echo "$status"
    echo '```'
  else
    echo "(変更なし)"
  fi
}

# --- プロジェクトコンテキストを取得 ---
get_project_context() {
  local context=""
  # CLAUDE.md があればプロジェクトルールとして渡す
  if [[ -f "CLAUDE.md" ]]; then
    context="${context}
### プロジェクトルール (CLAUDE.md)
$(head -50 CLAUDE.md)
"
  fi
  # .claude/CLAUDE.md もチェック
  if [[ -f ".claude/CLAUDE.md" ]]; then
    context="${context}
### プロジェクトルール (.claude/CLAUDE.md)
$(head -50 .claude/CLAUDE.md)
"
  fi
  echo "$context"
}

# --- ハンドオフメモを読む ---
get_handoff() {
  if [[ -f "$HANDOFF" && -s "$HANDOFF" ]]; then
    echo "### パートナーからの引き継ぎメモ"
    cat "$HANDOFF"
  fi
}

# --- ハンドオフ指示（プロンプトに追加する共通テキスト）---
HANDOFF_INSTRUCTION='

作業完了後、必ず .pair-handoff.md に以下の形式で引き継ぎメモを書いてください:

```markdown
## やったこと
- （変更内容を箇条書き）

## 判断の理由
- （なぜその方針にしたか、他の選択肢を選ばなかった理由）

## 次のパートナーへ
- （残タスク、注意点、改善すべき点）
```

これは次のパートナーが読むので、意図と文脈が伝わるように書いてください。'

# --- コミット ---
auto_commit() {
  local agent="$1"
  local round="$2"
  if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
    git add -A
    git commit -m "pair: ${agent} round ${round}" --no-verify 2>/dev/null || true
    local files_changed
    files_changed=$(git diff --stat HEAD~1 2>/dev/null | tail -1)
    log_info "コミット: ${agent} round ${round} (${files_changed})"
  else
    log_dim "変更なし - コミットスキップ"
  fi
}

# --- セットアップ ---
setup() {
  cd "$WORKDIR"
  mkdir -p "$LOG_DIR"

  if [[ -n "$(git status --porcelain 2>/dev/null)" ]]; then
    git add -A
    git commit -m "pair: initial state" --no-verify 2>/dev/null || true
  fi

  echo ""
  echo -e "${BOLD}╭──────────────────────────────────────╮${NC}"
  echo -e "${BOLD}│  Claude × Codex ペアプロ             │${NC}"
  echo -e "${BOLD}╰──────────────────────────────────────╯${NC}"
  echo ""
  log_info "タスク: ${TASK:0:80}"
  log_info "モード: $MODE | ラウンド: $ROUNDS | 先攻: $([ "$CLAUDE_FIRST" = true ] && echo 'Claude' || echo 'Codex') | タイムアウト: ${TIMEOUT}s"
}

# ============================================================
# モード実装
# ============================================================

mode_ping_pong() {
  local project_ctx
  project_ctx=$(get_project_context)

  # ハンドオフ初期化
  : > "$HANDOFF"

  for ((i=1; i<=ROUNDS; i++)); do
    log_step "ラウンド $i/$ROUNDS"

    local changes handoff_content
    changes=$(get_changes)
    handoff_content=$(get_handoff)

    local first_agent second_agent first_id second_id first_runner second_runner
    if [[ "$CLAUDE_FIRST" == true ]]; then
      first_agent="Claude" second_agent="Codex"
      first_id="claude" second_id="codex"
      first_runner="run_claude" second_runner="run_codex"
    else
      first_agent="Codex" second_agent="Claude"
      first_id="codex" second_id="claude"
      first_runner="run_codex" second_runner="run_claude"
    fi

    # --- 先攻のターン ---
    $first_runner "あなたはペアプログラミングの${first_agent}（先攻）です。
パートナーは ${second_agent} です。

## タスク
${TASK}

## 状況
ラウンド ${i}/${ROUNDS}

${project_ctx}
${handoff_content}
${changes}

## 指示
このタスクに取り組んでください。コードを実装・改善してください。
次のターンで ${second_agent} があなたの変更をレビュー・改善します。
${HANDOFF_INSTRUCTION}" "${LOG_DIR}/round${i}_${first_id}.log"
    auto_commit "${first_id}" "$i"

    # 先攻の diff + ハンドオフメモ取得
    local prev_diff
    prev_diff=$(git diff HEAD~1 2>/dev/null | head -300 || echo '(初回)')
    handoff_content=$(get_handoff)

    # --- 後攻のターン ---
    $second_runner "あなたはペアプログラミングの${second_agent}（後攻・レビュアー）です。
パートナーは ${first_agent} です。

## タスク
${TASK}

## 状況
ラウンド ${i}/${ROUNDS}

${project_ctx}
${handoff_content}

### ${first_agent} の変更（今回のラウンド）
$(git log -1 --format='コミット: %s' 2>/dev/null)
\`\`\`diff
${prev_diff}
\`\`\`

## 指示
${first_agent} の変更をレビューし、以下の観点で改善してください:
- バグ・ロジックエラーの修正
- 足りない処理の追加（エラーハンドリング、バリデーション等）
- コードの品質改善
- ${first_agent} のハンドオフメモの「次のパートナーへ」に書かれた課題への対応

${first_agent} の良い判断はそのまま維持してください。理由なく書き直さないでください。
${HANDOFF_INSTRUCTION}" "${LOG_DIR}/round${i}_${second_id}.log"
    auto_commit "${second_id}" "$i"
  done
}

mode_review() {
  local project_ctx
  project_ctx=$(get_project_context)
  : > "$HANDOFF"

  local impl_agent review_agent impl_id review_id impl_runner review_runner
  if [[ "$CLAUDE_FIRST" == true ]]; then
    impl_agent="Claude" review_agent="Codex"
    impl_id="claude" review_id="codex"
    impl_runner="run_claude" review_runner="run_codex"
  else
    impl_agent="Codex" review_agent="Claude"
    impl_id="codex" review_id="claude"
    impl_runner="run_codex" review_runner="run_claude"
  fi

  log_step "実装フェーズ (${impl_agent})"
  $impl_runner "あなたはペアプログラミングの実装担当です。

## タスク
${TASK}

${project_ctx}

## 指示
タスクを実装してください。
${HANDOFF_INSTRUCTION}" "${LOG_DIR}/implement.log"
  auto_commit "${impl_id}" "implement"

  log_step "レビューフェーズ (${review_agent})"
  local diff handoff_content
  diff=$(git diff HEAD~1 2>/dev/null | head -300 || git diff | head -300)
  handoff_content=$(get_handoff)

  $review_runner "あなたはペアプログラミングのレビュアーです。
${impl_agent} が実装したコードをレビューし、問題があれば修正してください。

## タスク
${TASK}

${project_ctx}
${handoff_content}

### ${impl_agent} の変更
\`\`\`diff
${diff}
\`\`\`

## 指示
- バグ・セキュリティ問題を修正
- ${impl_agent} のハンドオフメモの「次のパートナーへ」に対応
- 良い判断はそのまま維持。理由なく書き直さない
${HANDOFF_INSTRUCTION}" "${LOG_DIR}/review.log"
  auto_commit "${review_id}" "review"
}

mode_implement_review() {
  local project_ctx
  project_ctx=$(get_project_context)
  : > "$HANDOFF"

  # Step 1: Claude 実装
  log_step "Step 1/3: 実装 (Claude)"
  run_claude "あなたはペアプログラミングの実装担当です。

## タスク
${TASK}

${project_ctx}

## 指示
タスクを実装してください。
${HANDOFF_INSTRUCTION}" "${LOG_DIR}/step1_implement.log"
  auto_commit "claude" "implement"

  # Step 2: Codex レビュー（コード変更なし、レビューのみ）
  log_step "Step 2/3: レビュー (Codex)"
  local diff handoff_content
  diff=$(git diff HEAD~1 2>/dev/null | head -300 || echo "(初回実装)")
  handoff_content=$(get_handoff)

  run_codex "あなたはペアプログラミングのレビュアーです。
コードを変更せず、レビュー結果を review.md に書き出してください。

## タスク
${TASK}

${project_ctx}
${handoff_content}

### Claude の変更
\`\`\`diff
${diff}
\`\`\`

## レビュー観点
review.md に以下の形式で書いてください:
\`\`\`markdown
## 良い点
- （維持すべき判断）

## 要修正
- （バグ、ロジックエラー、セキュリティ問題）

## 改善提案
- （品質向上、パフォーマンス、テスト等）

## 優先度
1. （最も重要な修正）
2. ...
\`\`\`

コードファイルは変更しないでください。review.md のみ書いてください。" "${LOG_DIR}/step2_review.log"
  auto_commit "codex" "review"

  # Step 3: Claude がレビュー反映
  log_step "Step 3/3: 修正 (Claude)"
  local review_content=""
  [[ -f review.md ]] && review_content=$(cat review.md)

  run_claude "あなたはペアプログラミングの実装担当です。
Codex からのレビューを反映してコードを修正してください。

## タスク
${TASK}

${project_ctx}

### Codex のレビュー
${review_content}

## 指示
- レビューの「要修正」は必ず対応
- 「改善提案」は妥当なら対応、過剰なら見送ってよい
- 修正理由を明確に。review.md は削除してよい
${HANDOFF_INSTRUCTION}" "${LOG_DIR}/step3_fix.log"
  auto_commit "claude" "fix"
}

mode_parallel() {
  local project_ctx base_branch
  project_ctx=$(get_project_context)
  base_branch=$(git branch --show-current)

  local claude_dir codex_dir
  claude_dir=$(mktemp -d)
  codex_dir=$(mktemp -d)

  git worktree add "$claude_dir" -b pair-claude 2>/dev/null || {
    git branch -D pair-claude 2>/dev/null || true
    git worktree add "$claude_dir" -b pair-claude
  }
  git worktree add "$codex_dir" -b pair-codex 2>/dev/null || {
    git branch -D pair-codex 2>/dev/null || true
    git worktree add "$codex_dir" -b pair-codex
  }

  log_step "並行実装（worktree分離）"

  (
    cd "$claude_dir"
    log_claude "worktree: $claude_dir"
    run_claude "あなたはペアプログラミングの Claude 担当です。
Codex も同じタスクを並行で実装中です。後でマージされます。

## タスク
${TASK}

${project_ctx}

## 指示
タスクを実装してください。
${HANDOFF_INSTRUCTION}" "${WORKDIR}/${LOG_DIR}/parallel_claude.log"
    git add -A && git commit -m "pair: claude parallel" --no-verify 2>/dev/null || true
  ) &
  local claude_pid=$!

  (
    cd "$codex_dir"
    log_codex "worktree: $codex_dir"
    run_codex "あなたはペアプログラミングの Codex 担当です。
Claude も同じタスクを並行で実装中です。後でマージされます。

## タスク
${TASK}

${project_ctx}

タスクを実装してください。" "${WORKDIR}/${LOG_DIR}/parallel_codex.log"
    git add -A && git commit -m "pair: codex parallel" --no-verify 2>/dev/null || true
  ) &
  local codex_pid=$!

  wait $claude_pid || true
  wait $codex_pid || true

  # ハンドオフメモを読んでマージ判断に使う
  local claude_handoff="" codex_handoff=""
  [[ -f "${claude_dir}/.pair-handoff.md" ]] && claude_handoff=$(cat "${claude_dir}/.pair-handoff.md")
  [[ -f "${codex_dir}/.pair-handoff.md" ]] && codex_handoff=$(cat "${codex_dir}/.pair-handoff.md")

  log_step "マージ"
  git merge pair-claude --no-edit 2>/dev/null || true
  git merge pair-codex --no-edit 2>/dev/null || {
    log_info "コンフリクト発生 → Claude に解決させます..."
    run_claude "git merge のコンフリクトを解決してください。

## タスク
${TASK}

### Claude の実装メモ
${claude_handoff}

### Codex の実装メモ
${codex_handoff}

## 指示
両方の実装の良い部分を残してマージしてください。
判断理由が明確な方を優先してください。" "${LOG_DIR}/merge_resolve.log"
    git add -A
    git commit -m "pair: merge resolution" --no-verify 2>/dev/null || true
  }

  git worktree remove "$claude_dir" 2>/dev/null || true
  git worktree remove "$codex_dir" 2>/dev/null || true
  git branch -D pair-claude pair-codex 2>/dev/null || true
}

# ============================================================
# メイン
# ============================================================

check_deps
setup

PAIR_START=$(date +%s)

case "$MODE" in
  ping-pong)        mode_ping_pong ;;
  review)           mode_review ;;
  implement-review) mode_implement_review ;;
  parallel)         mode_parallel ;;
  *)                log_error "不明なモード: $MODE"; usage ;;
esac

# --- サマリ ---
PAIR_ELAPSED=$(( $(date +%s) - PAIR_START ))
echo ""
echo -e "${BOLD}╭──────────────────────────────────────╮${NC}"
echo -e "${BOLD}│  ペアプロ完了                        │${NC}"
echo -e "${BOLD}╰──────────────────────────────────────╯${NC}"
echo ""
log_info "合計時間: $(fmt_elapsed $PAIR_ELAPSED)"
log_info "コミット履歴:"
git log --oneline --graph -10 2>/dev/null || true
echo ""
log_info "ログ: ${LOG_DIR}/"

# コスト集計（ログからUSD抽出）
total_cost=0
for f in "${LOG_DIR}"/*.log; do
  [[ -f "$f" ]] || continue
  cost=$(grep -o '"total_cost_usd":[0-9.]*' "$f" 2>/dev/null | tail -1 | cut -d: -f2)
  if [[ -n "$cost" ]]; then
    total_cost=$(echo "$total_cost + $cost" | bc 2>/dev/null || echo "$total_cost")
  fi
done
if (( $(echo "$total_cost > 0" | bc 2>/dev/null || echo 0) )); then
  log_info "合計コスト: \$${total_cost}"
fi
